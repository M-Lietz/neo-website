---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'NEO — Self-Hosted AI auf Custom Hardware | Merlin Lietz',
  description = 'Ein KI-Agent auf einem MiniPC. Self-Hosted, Open Source, Null Cloud. 16 Services, 15 Automationen, 11 KI-Modelle. Gebaut von Merlin Lietz.',
} = Astro.props

const ogImage = `${Astro.url.origin}/img/og-image.png`
const canonicalUrl = Astro.url.href
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#081020" />
    <meta name="author" content="Merlin Lietz" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="NEO — Self-Hosted AI" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="preload" as="image" href="/img/neo-avatar.jpg" />

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "NEO — Self-Hosted AI",
      "url": "https://neo.lietztech.com",
      "description": description,
      "author": {
        "@type": "Person",
        "name": "Merlin Lietz",
        "url": "https://merlinlietz.com",
        "sameAs": [
          "https://github.com/M-Lietz",
          "https://www.fiverr.com/merlinlietz"
        ]
      }
    })} />
    <title>{title}</title>
  </head>
  <body class="bg-bg-primary text-text-primary antialiased">
    <!-- Skip to Content (Accessibility) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[60] focus:bg-accent-purple focus:text-white focus:px-4 focus:py-2 focus:rounded focus:text-sm">Zum Inhalt springen</a>

    <noscript>
      <div style="background:#081020;color:#e4eaf5;text-align:center;padding:2rem;font-family:system-ui">
        <h1>NEO — Self-Hosted AI</h1>
        <p>Diese Website benötigt JavaScript für 3D-Effekte und Animationen.</p>
        <p>Bitte aktivieren Sie JavaScript für das beste Erlebnis.</p>
      </div>
    </noscript>

    <!-- 3D Background Canvas (Three.js) — hinter HTML -->
    <canvas id="bg-canvas" class="fixed inset-0 -z-10"></canvas>
    <!-- 3D Foreground Canvas — über HTML, transparent, keine Mausevents -->
    <canvas id="fg-canvas" class="fixed inset-0 z-10 pointer-events-none"></canvas>

    <!-- EFFEKT #5: Chromatic Aberration (entfernen = dieses div löschen) -->
    <div class="chromatic-aberration"></div>

    <!-- EFFEKT #6: Film Grain (entfernen = dieses div löschen) -->
    <div class="film-grain"></div>

    <!-- EFFEKT #7: God Rays (entfernen = dieses div löschen) -->
    <div class="god-rays"></div>

    <!-- Scroll Progress Bar -->
    <div id="scroll-progress" class="fixed top-0 left-0 h-0.5 bg-gradient-to-r from-accent-purple via-accent-cyan to-accent-pink z-50 transition-[width] duration-150"></div>

    <!-- Main Content -->
    <div id="main-content">
      <slot />
    </div>

    <!-- GSAP + Three.js init -->
    <script>
      document.addEventListener('DOMContentLoaded', async () => {
        // GSAP lazy laden
        const { initScrollAnimations } = await import('../lib/animations')
        initScrollAnimations()

        // Three.js nur auf Desktop laden (hover-fähig + breiter Screen)
        const isDesktop = window.matchMedia('(hover: hover) and (min-width: 768px)').matches
        const bgCanvas = document.getElementById('bg-canvas') as HTMLCanvasElement
        const fgCanvas = document.getElementById('fg-canvas') as HTMLCanvasElement

        if (isDesktop && bgCanvas && fgCanvas) {
          const { initBackground } = await import('../lib/three-bg')
          initBackground(bgCanvas, fgCanvas)
        } else {
          // Mobile: Canvases ausblenden, kein Three.js
          bgCanvas?.remove()
          fgCanvas?.remove()
        }

        // Scroll progress bar
        window.addEventListener('scroll', () => {
          const h = document.documentElement
          const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100
          const bar = document.getElementById('scroll-progress')
          if (bar) bar.style.width = `${pct}%`
        }, { passive: true })

        // Web Vitals — lightweight RUM logging
        if ('PerformanceObserver' in window) {
          try {
            // LCP
            new PerformanceObserver((list) => {
              const entries = list.getEntries()
              const lcp = entries[entries.length - 1]
              console.log('[Vitals] LCP:', Math.round(lcp.startTime), 'ms')
            }).observe({ type: 'largest-contentful-paint', buffered: true })

            // CLS
            let clsValue = 0
            new PerformanceObserver((list) => {
              for (const entry of list.getEntries()) {
                if (!(entry as any).hadRecentInput) clsValue += (entry as any).value
              }
              console.log('[Vitals] CLS:', clsValue.toFixed(3))
            }).observe({ type: 'layout-shift', buffered: true })

            // FCP
            new PerformanceObserver((list) => {
              const fcp = list.getEntries().find(e => e.name === 'first-contentful-paint')
              if (fcp) console.log('[Vitals] FCP:', Math.round(fcp.startTime), 'ms')
            }).observe({ type: 'paint', buffered: true })
          } catch {}
        }
      })
    </script>
  </body>
</html>
