---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/ui/Nav.astro'
import Extras from '../components/ui/Extras.astro'
import Hero from '../components/sections/Hero.astro'
import Terminal from '../components/sections/Terminal.astro'
import Dashboard from '../components/sections/Dashboard.astro'
import ActivityFeed from '../components/sections/ActivityFeed.astro'
import DailySignal from '../components/sections/DailySignal.astro'
import TelegramFeed from '../components/sections/TelegramFeed.astro'
import About from '../components/sections/About.astro'
import Timeline from '../components/sections/Timeline.astro'
import TechStack from '../components/sections/TechStack.astro'
import Guestbook from '../components/sections/Guestbook.astro'
import Achievements from '../components/sections/Achievements.astro'
import Contact from '../components/sections/Contact.astro'
import Newsletter from '../components/sections/Newsletter.astro'
import Footer from '../components/ui/Footer.astro'
---

<BaseLayout>
  <Extras />
  <Nav />
  <main>
    <Hero />
    <Terminal />
    <Dashboard />
    <ActivityFeed />
    <DailySignal />
    <TelegramFeed />
    <About />
    <Timeline />
    <TechStack />
    <Guestbook />
    <Achievements />
    <Contact />
    <Newsletter />
  </main>
  <Footer />
</BaseLayout>
