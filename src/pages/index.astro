<BaseLayout title="NEO — Self-Hosted AI auf Custom Hardware | Merlin Lietz" description="Ein KI-Agent auf einem MiniPC. Self-Hosted, Open Source, Null Cloud. Gebaut von Merlin Lietz.">
  <Extras />
  <Nav />
  <main>
    <Hero />
    <Ticker />
    <div class="section-divider"></div>
    <WasIstNeo />
    <div class="section-divider"></div>
    <Dashboard />
    <div class="section-divider"></div>
    <Terminal />
    <div class="section-divider"></div>
    <TechStack />
    <div class="section-divider"></div>
    <Timeline />
    <div class="section-divider"></div>
    <About />
    <div class="section-divider"></div>
    <Connect />
  </main>
  <Footer />
</BaseLayout>
