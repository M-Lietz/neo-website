    <ServiceGrid />
    <div class="section-divider"></div>
    <Terminal />
    <div class="section-divider"></div>
    <AIModelRoster />
    <div class="section-divider"></div>
    <AutomationTimeline />
    <div class="section-divider"></div>
    <CostTicker />
    <div class="section-divider"></div>
    <TechStack />
    <div class="section-divider"></div>
    <Timeline />
    <div class="section-divider"></div>
    <About />
