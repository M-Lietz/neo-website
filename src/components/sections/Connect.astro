---
/**
 * Connect Section — Links zu Profilen & Portfolio
 * GitHub, Fiverr, Portfolio, Telegram
 */
---

<section id="connect" class="px-4 sm:px-6 py-20" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-3 max-w-4xl mx-auto title-glow">
    <span class="title-glow-line"></span>// Connect
  </h2>
  <p class="text-text-secondary text-sm max-w-4xl mx-auto mb-10 pl-[52px]">
    Projekt anschauen, Profil checken oder direkt schreiben.
  </p>

  <div class="max-w-4xl mx-auto grid sm:grid-cols-2 lg:grid-cols-4 gap-4" data-stagger-parent>

    <!-- GitHub -->
    <a href="https://github.com/M-Lietz" target="_blank" rel="noopener"
      class="glass-card p-6 text-center group hover:border-accent-purple/30 transition-all duration-300" data-stagger-child>
      <div class="text-4xl mb-3 group-hover:scale-110 transition-transform">🐙</div>
      <h3 class="text-sm font-semibold text-text-primary mb-1">GitHub</h3>
      <p class="text-xs text-text-muted">Code, Projekte, Open Source</p>
      <span class="block mt-3 text-xs font-mono text-accent-purple group-hover:text-accent-cyan transition-colors">→ github.com/M-Lietz</span>
    </a>

    <!-- Fiverr -->
    <a href="https://www.fiverr.com/merlinlietz" target="_blank" rel="noopener"
      class="glass-card p-6 text-center group hover:border-accent-green/30 transition-all duration-300" data-stagger-child>
      <div class="text-4xl mb-3 group-hover:scale-110 transition-transform">💼</div>
      <h3 class="text-sm font-semibold text-text-primary mb-1">Fiverr</h3>
      <p class="text-xs text-text-muted">Aufträge & Freelancing</p>
      <span class="block mt-3 text-xs font-mono text-accent-green group-hover:text-accent-cyan transition-colors">→ fiverr.com/merlinlietz</span>
    </a>

    <!-- Portfolio -->
    <a href="https://merlinlietz.com" target="_blank" rel="noopener"
      class="glass-card p-6 text-center group hover:border-accent-cyan/30 transition-all duration-300" data-stagger-child>
      <div class="text-4xl mb-3 group-hover:scale-110 transition-transform">🌐</div>
      <h3 class="text-sm font-semibold text-text-primary mb-1">Portfolio</h3>
      <p class="text-xs text-text-muted">Über mich, Services, Kontakt</p>
      <span class="block mt-3 text-xs font-mono text-accent-cyan group-hover:text-accent-purple transition-colors">→ merlinlietz.com</span>
    </a>

    <!-- Telegram -->
    <a href="https://t.me/merlin_neo_ai_bot" target="_blank" rel="noopener"
      class="glass-card p-6 text-center group hover:border-accent-pink/30 transition-all duration-300" data-stagger-child>
      <div class="text-4xl mb-3 group-hover:scale-110 transition-transform">💬</div>
      <h3 class="text-sm font-semibold text-text-primary mb-1">Telegram</h3>
      <p class="text-xs text-text-muted">Direkt mit Neo chatten</p>
      <span class="block mt-3 text-xs font-mono text-accent-pink group-hover:text-accent-cyan transition-colors">→ @merlin_neo_ai_bot</span>
    </a>

  </div>
</section>
