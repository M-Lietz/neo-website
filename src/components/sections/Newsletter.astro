---
/**
 * Newsletter Section — Email subscribe
 * Uses neo_newsletter_subscribe AJAX endpoint
 */
---

<section id="newsletter" class="px-4 sm:px-6 py-12" data-animate>
  <div class="max-w-2xl mx-auto glass-card p-6 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-accent-purple/5 via-transparent to-accent-cyan/5 pointer-events-none"></div>
    <span class="text-xs font-mono text-accent-cyan mb-2 block relative">// Newsletter</span>
    <h3 class="text-lg font-semibold text-text-primary mb-2 relative">Bleib im Loop</h3>
    <p class="text-sm text-text-secondary mb-4 relative">Updates zu Homelab, KI und Self-Hosting — kein Spam, versprochen.</p>
    <form id="newsletter-form" class="flex gap-2 max-w-md mx-auto relative">
      <input type="email" name="email" placeholder="deine@email.de" required
        class="flex-1 px-3 py-2 bg-white/5 border border-border-glass rounded-lg text-sm text-text-primary placeholder-text-muted outline-none focus:border-accent-purple/50 transition-colors" />
      <button type="submit" class="px-4 py-2 rounded-lg bg-accent-purple/20 border border-accent-purple/30 text-sm font-mono text-accent-purple hover:bg-accent-purple/30 transition-colors whitespace-nowrap">
        Abonnieren
      </button>
    </form>
    <div id="nl-status" class="text-xs font-mono mt-2 relative hidden"></div>
  </div>
</section>

<script>
  import { wpAjax } from '../../lib/api'

  const form = document.getElementById('newsletter-form') as HTMLFormElement
  const status = document.getElementById('nl-status')

  form?.addEventListener('submit', async (ev) => {
    ev.preventDefault()
    const email = (new FormData(form).get('email') as string)?.trim()
    if (!email) return

    if (status) { status.textContent = 'Wird eingetragen...'; status.className = 'text-xs font-mono mt-2 relative text-accent-cyan' }

    const res = await wpAjax<any>('neo_newsletter_subscribe', { email })
    if (res?.success !== false) {
      form.reset()
      if (status) { status.textContent = '✓ Willkommen an Bord!'; status.className = 'text-xs font-mono mt-2 relative text-accent-green' }
    } else {
      if (status) { status.textContent = '✗ Fehler beim Eintragen.'; status.className = 'text-xs font-mono mt-2 relative text-accent-red' }
    }
    setTimeout(() => { if (status) status.className = 'text-xs font-mono mt-2 relative hidden' }, 4000)
  })
</script>
