---
/**
 * ServiceGrid — Alle laufenden Services als Status-Grid
 * Klick auf Karte → expandiert Details
 */
const services = [
  { name: 'OpenClaw Gateway', desc: 'KI-Agent Core — LLM-Router + Tool-System', status: 'online', icon: '🦞', port: '18789', uptime: '180d',
    detail: 'Selbst geschriebener Python-Agent. Routet Anfragen an 11 KI-Modelle via LiteLLM. Tool-System für Dateien, Suche, APIs. Gateway-Port 18789.' },
  { name: 'Telegram Bot', desc: '@merlin_neo_ai_bot — 24/7 interaktiv', status: 'online', icon: '💬', port: 'API', uptime: '180d',
    detail: 'Inline Keyboards, Callback-Handling, Voice-Messages, Kanal-Automatisierung. 7 Automationen + Content-Pipeline für tägliche Posts.' },
  { name: 'SearXNG', desc: 'Meta-Suchmaschine — 60+ Backends', status: 'online', icon: '🔍', port: '8080', uptime: '90d',
    detail: 'Privacy-Suchmaschine ohne Tracking. Aggregiert Google, Bing, DuckDuckGo und 60+ weitere Quellen. Gecacht via Valkey/Redis.' },
  { name: 'Paperless-ngx', desc: 'Dokumenten-OCR & Archiv', status: 'online', icon: '📄', port: '8010', uptime: '120d',
    detail: 'Automatische OCR-Texterkennung, Tag-basierte Organisation, Volltextsuche über 200+ Dokumente. API-Zugriff via Token.' },
  { name: 'Caddy', desc: 'HTTPS Reverse Proxy + Auto-TLS', status: 'online', icon: '🌐', port: '443', uptime: '180d',
    detail: 'Automatische Let\'s Encrypt Zertifikate, Zero-Config HTTPS für alle internen Services. Caddyfile mit 8 Proxy-Regeln.' },
  { name: 'Gotify', desc: 'Push-Notification Server', status: 'online', icon: '🔔', port: '8090', uptime: '150d',
    detail: 'Self-hosted Push-Server. Sendet System-Alerts (Container down, Backup fertig, Mail empfangen) direkt aufs Handy.' },
  { name: 'n8n', desc: 'Workflow-Automation (LXC 101)', status: 'online', icon: '⚡', port: '5678', uptime: '90d',
    detail: 'Läuft in eigenem LXC Container. 14 Workflows: Telegram-Callbacks, E-Mail-Monitoring, Maintenance-Scripts, Cron-Jobs.' },
  { name: 'Browserless', desc: 'Headless Chrome API — Scraping & Screenshots', status: 'online', icon: '🖥️', port: '3000', uptime: '60d',
    detail: 'Headless Chrome als Docker-Service. Neo nutzt es für Web-Scraping, Screenshot-Generierung und PDF-Rendering.' },
  { name: 'Valkey', desc: 'Redis-kompatibler Cache für SearXNG', status: 'online', icon: '💾', port: '6379', uptime: '90d',
    detail: 'Open-Source Redis-Fork. Cached SearXNG-Queries und Session-Daten. Kein Datenverlust bei Restart dank AOF.' },
  { name: 'Cloudflare Tunnel', desc: 'Sichere Extern-Anbindung — kein offener Port', status: 'connected', icon: '☁️', port: '—', uptime: '180d',
    detail: 'Zero-Trust Tunnel: Kein einziger Port muss geöffnet werden. Cloudflare routet Traffic verschlüsselt direkt zum Server.' },
  { name: 'Gmail Integration', desc: 'himalaya CLI — E-Mail senden & empfangen', status: 'connected', icon: '📧', port: 'IMAP', uptime: '—',
    detail: 'himalaya CLI für IMAP/SMTP. Neo kann E-Mails lesen, filtern und antworten — alles über die Kommandozeile.' },
  { name: 'Google Calendar', desc: 'Kalender-Sync via gog CLI', status: 'synced', icon: '📅', port: 'API', uptime: '—',
    detail: 'gog CLI synchronisiert Google Calendar Events. Neo kann Termine anlegen, löschen und als Reminder versenden.' },
  { name: 'GitHub', desc: 'gh CLI — Repos, Issues, PRs', status: 'connected', icon: '🐙', port: 'API', uptime: '—',
    detail: 'GitHub CLI für alles: Repos erstellen, Issues bearbeiten, PRs mergen, Releases taggen. Alles automatisierbar.' },
  { name: 'ElevenLabs TTS', desc: 'Text-to-Speech (Deutsch, Conrad)', status: 'connected', icon: '🔊', port: 'API', uptime: '—',
    detail: 'Text-to-Speech API mit deutscher Stimme "Conrad". Generiert Audio-Nachrichten für den Telegram-Kanal.' },
  { name: 'Whisper STT', desc: 'Speech-to-Text via OpenAI', status: 'connected', icon: '🎤', port: 'API', uptime: '—',
    detail: 'OpenAI Whisper transkribiert Voice-Messages in Text. Merlin spricht, Neo versteht — ohne manuelles Tippen.' },
  { name: 'WordPress', desc: 'merlinlietz.com Portfolio-Site', status: 'online', icon: '📰', port: '80', uptime: '120d',
    detail: 'Läuft in LXC 113. Portfolio + Blog mit Custom Theme. REST API für automatisierte Blog-Posts via n8n.' },
]

const statusStyles: Record<string, { color: string; label: string }> = {
  online: { color: 'text-accent-green', label: '● online' },
  connected: { color: 'text-accent-cyan', label: '● connected' },
  synced: { color: 'text-accent-purple', label: '● synced' },
}
---

<section id="services" class="px-4 sm:px-6 py-16" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-1 max-w-5xl mx-auto title-glow">
    <span class="title-glow-line"></span>// Service Grid
  </h2>
  <p class="text-text-secondary text-sm max-w-5xl mx-auto mb-2 pl-[52px]">
    Alles was auf diesem MiniPC läuft — ein ganzes Datacenter in einer Box.
  </p>
  <p class="text-text-muted text-xs max-w-5xl mx-auto mb-8 pl-[52px] font-mono">
    {services.length} Services · {services.filter(s => s.status === 'online').length} Container · {services.filter(s => s.status === 'connected').length} externe Integrationen
  </p>

  <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3" data-stagger-parent>
    {services.map((s) => {
      const st = statusStyles[s.status]
      return (
        <details class="glass-expand service-tile" data-stagger-child>
          <summary class="glass-card p-3 hover:border-accent-cyan/20 transition-all duration-300 group cursor-pointer list-none">
            <div class="flex items-start gap-2 mb-2">
              <span class="text-lg group-hover:scale-110 transition-transform">{s.icon}</span>
              <div class="flex-1 min-w-0">
                <h3 class="text-xs font-semibold text-text-primary truncate">{s.name}</h3>
                <span class={`text-[9px] font-mono ${st.color}`}>{st.label}</span>
              </div>
              <svg class="expand-chevron w-3 h-3 text-text-muted mt-0.5 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
            <p class="text-[10px] text-text-muted mb-2">{s.desc}</p>
            <div class="flex items-center justify-between text-[9px] font-mono text-text-muted border-t border-white/5 pt-1.5">
              <span>:{s.port}</span>
              {s.uptime !== '—' && <span class="text-accent-green">⬆ {s.uptime}</span>}
            </div>
          </summary>
          <div class="expand-content">
            <div class="expand-inner">
              <div class="px-3 pb-3 pt-1">
                <p class="text-[10px] text-text-secondary leading-relaxed">{s.detail}</p>
              </div>
            </div>
          </div>
        </details>
      )
    })}
  </div>

  <!-- Stats Bar -->
  <div class="max-w-5xl mx-auto mt-6 glass-panel p-3 flex flex-wrap items-center justify-center gap-6 text-xs font-mono" data-animate>
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-accent-green animate-pulse"></span>
      <span class="text-text-muted">All Systems Operational</span>
    </div>
    <span class="text-text-muted">·</span>
    <span class="text-text-secondary">{services.length} Services</span>
    <span class="text-text-muted">·</span>
    <span class="text-text-secondary">1 physischer Host</span>
    <span class="text-text-muted">·</span>
    <span class="text-accent-green">€0/Monat Cloud</span>
  </div>
</section>

<script>
  // Staggered status blink on scroll into view
  const tiles = document.querySelectorAll<HTMLElement>('.service-tile')
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        tiles.forEach((tile, i) => {
          setTimeout(() => {
            tile.style.opacity = '0'
            tile.style.transform = 'translateY(8px)'
            requestAnimationFrame(() => {
              tile.style.transition = 'all 0.4s ease-out'
              tile.style.opacity = '1'
              tile.style.transform = 'translateY(0)'
            })
          }, i * 50)
        })
        observer.disconnect()
      }
    })
  }, { threshold: 0.1 })

  if (tiles.length) observer.observe(tiles[0].closest('section')!)
</script>
