---
/**
 * Services Section — 8 interactive glass service cards
 * Core offering: Was wir für dich bauen können.
 */
const services = [
  {
    icon: '🌐',
    title: 'Websites',
    desc: 'Moderne, schnelle Websites mit Astro, Next.js oder WordPress. Performance-optimiert und SEO-ready.',
    features: ['Landing Pages', 'Portfolio Sites', 'Corporate Websites'],
    color: 'accent-purple',
  },
  {
    icon: '⚡',
    title: 'Automatisierung',
    desc: 'n8n-Workflows, Cron-Jobs, API-Integrationen. Alles was repetitiv ist, wird automatisiert.',
    features: ['n8n Workflows', 'API-Integrationen', 'Cron-Jobs'],
    color: 'accent-cyan',
  },
  {
    icon: '📊',
    title: 'Dashboards',
    desc: 'Echtzeit-Dashboards für deine Daten. Von System-Monitoring bis Business-Analytics.',
    features: ['Live-Monitoring', 'KPIs & Charts', 'Custom Widgets'],
    color: 'accent-pink',
  },
  {
    icon: '🔒',
    title: 'Self-Hosted',
    desc: 'Deine Daten auf deinem Server. Paperless, Nextcloud, GitLab — wir richten alles ein.',
    features: ['Docker Setup', 'Backup-Systeme', 'SSL & Security'],
    color: 'accent-blue',
  },
  {
    icon: '🤖',
    title: 'Chatbots',
    desc: 'KI-gestützte Chatbots für Telegram, WhatsApp oder deine Website. Mit LLM-Power.',
    features: ['Telegram Bots', 'Website Chat', 'LLM-Integration'],
    color: 'accent-green',
  },
  {
    icon: '🖥️',
    title: 'Server-Pakete',
    desc: 'Komplette Server-Setups: VPS einrichten, Docker, Reverse Proxy, Monitoring — alles inklusive.',
    features: ['VPS Setup', 'Docker Compose', 'Monitoring'],
    color: 'accent-purple',
  },
  {
    icon: '📧',
    title: 'E-Mail-Marketing',
    desc: 'Professionelle E-Mail-Kampagnen mit eigenem Mailserver. DSGVO-konform und self-hosted.',
    features: ['Newsletter-System', 'Automationen', 'Templates'],
    color: 'accent-cyan',
  },
  {
    icon: '🛒',
    title: 'Online-Shops',
    desc: 'WooCommerce oder headless E-Commerce. Payment, Versand, Lagerverwaltung — alles integriert.',
    features: ['WooCommerce', 'Stripe/PayPal', 'Bestandsverwaltung'],
    color: 'accent-pink',
  },
]
---

<section id="services" class="px-4 sm:px-6 py-20" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-3 max-w-6xl mx-auto title-glow">
    <span class="title-glow-line"></span>// Services
  </h2>
  <p class="text-text-secondary text-sm max-w-6xl mx-auto mb-8 pl-[52px]">
    Was du hier siehst, bauen wir auch für dich. Gleiche Qualität, gleiche Technik.
  </p>

  <div class="max-w-6xl mx-auto grid sm:grid-cols-2 lg:grid-cols-4 gap-4" data-stagger-parent>
    {services.map((svc) => (
      <div class="glass-card p-5 group hover:border-accent-purple/30 transition-all duration-300 cursor-pointer service-card" data-stagger-child>
        <!-- Icon -->
        <div class="text-3xl mb-3 group-hover:scale-110 transition-transform duration-300">{svc.icon}</div>
        <!-- Title -->
        <h3 class={`text-sm font-mono font-semibold text-${svc.color} mb-2`}>{svc.title}</h3>
        <!-- Description -->
        <p class="text-xs text-text-muted leading-relaxed mb-3">{svc.desc}</p>
        <!-- Feature tags -->
        <div class="flex flex-wrap gap-1">
          {svc.features.map(f => (
            <span class="px-2 py-0.5 text-[10px] font-mono rounded bg-white/5 text-text-muted group-hover:text-text-secondary transition-colors">{f}</span>
          ))}
        </div>
        <!-- Hover CTA -->
        <div class="mt-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <span class={`text-[10px] font-mono text-${svc.color}`}>Mehr erfahren →</span>
        </div>
      </div>
    ))}
  </div>

  <!-- Bottom CTA -->
  <div class="max-w-6xl mx-auto text-center mt-10">
    <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-mono text-sm font-medium text-text-primary border border-border-glass hover:border-accent-cyan/50 hover:bg-accent-cyan/5 transition-all duration-300">
      Projekt anfragen <span class="text-accent-cyan">→</span>
    </a>
  </div>
</section>
