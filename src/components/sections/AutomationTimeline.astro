---
/**
 * AutomationTimeline — 24h-Zeitstrahl mit allen Automationen
 * Zeigt was Neo jeden Tag automatisch erledigt, Echtzeit-Marker
 */
const automations = [
  { time: '03:00', icon: '🧹', title: 'Voice-Cleanup', desc: 'Alte Sprach-Medien löschen (>7 Tage)', model: 'flash', cost: '$0.001' },
  { time: '07:15', icon: '📅', title: 'Kalender-Briefing', desc: 'Google Calendar → Telegram-Zusammenfassung', model: 'flash', cost: '$0.002' },
  { time: '07:30', icon: '☀️', title: 'Guten Morgen', desc: 'Wetter + HomeLab-Status + GitHub Trending', model: 'pro', cost: '$0.01' },
  { time: '08:00', icon: '🔥', title: 'GitHub Trending', desc: 'Top 5 Repos des Tages — täglich kuratiert', model: 'pro', cost: '$0.008' },
  { time: '09:00', icon: '📊', title: 'System Status', desc: 'Docker, RAM, Disk, Gateway — alles gecheckt', model: 'pro', cost: '$0.005' },
  { time: '10:00', icon: '🔍', title: 'Promo-Monitor', desc: 'OpenRouter Promo-Preise überwachen', model: 'flash', cost: '$0.001' },
  { time: '10:30', icon: '🎨', title: 'Kreativ-Content', desc: 'Telegram-Kanal: Bild + Text + Audio generieren', model: 'pro', cost: '$0.02' },
  { time: '12:30', icon: '☀️', title: 'Mittags-Check', desc: 'Kurzer Status-Puls: alles läuft?', model: 'flash', cost: '$0.001' },
  { time: '19:30', icon: '🎨', title: 'Abend-Content', desc: 'Zweite Content-Welle für den Kanal', model: 'pro', cost: '$0.02' },
  { time: '20:00', icon: '🌙', title: 'Guten Abend', desc: 'Tagesrückblick + Morgen-Preview + Wetter', model: 'pro', cost: '$0.01' },
  { time: '21:00', icon: '📊', title: 'Abend-Status', desc: 'Docker Health + System-Metriken', model: 'pro', cost: '$0.005' },
  { time: '21:00', icon: '📈', title: 'Daily Lab Report', desc: 'Kanal-Statistiken + Content-Performance', model: 'flash', cost: '$0.002' },
]

// Wochentags-only Jobs
const weeklyJobs = [
  { day: 'Mo + Do', time: '10:00', icon: '🐛', title: 'Issue-Tracker', desc: 'MiMo GitHub Issues überwachen' },
  { day: 'Sonntag', time: '11:30', icon: '🔎', title: 'Skill Report', desc: 'Wöchentlicher OpenClaw-Überblick' },
]
---

<section id="automations" class="px-4 sm:px-6 py-16" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-1 max-w-5xl mx-auto title-glow">
    <span class="title-glow-line"></span>// 24h Automation Timeline
  </h2>
  <p class="text-text-secondary text-sm max-w-5xl mx-auto mb-2 pl-[52px]">
    Was Neo jeden Tag automatisch erledigt — ohne dass jemand einen Finger rührt.
  </p>
  <p class="text-text-muted text-xs max-w-5xl mx-auto mb-8 pl-[52px] font-mono">
    {automations.length} tägliche Jobs · {weeklyJobs.length} wöchentliche Jobs · <span class="text-accent-green">Nächste Automation: <span id="next-auto-time">—</span></span>
  </p>

  <div class="max-w-5xl mx-auto">
    <!-- Horizontal Timeline Bar -->
    <div class="relative mb-10 hidden md:block">
      <div class="h-1 rounded-full bg-white/5 relative overflow-visible">
        <!-- Time progress fill -->
        <div id="time-progress" class="absolute inset-y-0 left-0 rounded-full bg-gradient-to-r from-accent-purple via-accent-cyan to-accent-green transition-all duration-1000" style="width: 0%"></div>
        <!-- Dots for each automation -->
        {automations.map((a) => {
          const [h, m] = a.time.split(':').map(Number)
          const pct = ((h * 60 + m) / 1440) * 100
          return (
            <div class="absolute top-1/2 -translate-y-1/2 group cursor-pointer z-10" style={`left: ${pct}%`} data-auto-time={a.time}>
              <div class="w-3 h-3 rounded-full bg-bg-secondary border-2 border-accent-purple group-hover:bg-accent-purple group-hover:shadow-[0_0_12px_rgba(126,180,245,0.5)] transition-all duration-300 -translate-x-1/2"></div>
              <!-- Tooltip -->
              <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 z-20">
                <div class="glass-card px-3 py-2 text-[10px] font-mono whitespace-nowrap">
                  <div class="text-accent-cyan">{a.time} · {a.icon} {a.title}</div>
                  <div class="text-text-muted">{a.desc}</div>
                  <div class="text-accent-green">{a.cost}/run</div>
                </div>
              </div>
            </div>
          )
        })}
      </div>
      <!-- Hour markers -->
      <div class="flex justify-between mt-2 text-[9px] font-mono text-text-muted px-1">
        <span>00:00</span><span>04:00</span><span>08:00</span><span>12:00</span><span>16:00</span><span>20:00</span><span>24:00</span>
      </div>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" data-stagger-parent>
      {automations.map((a) => (
        <div class="glass-card p-3 hover:border-accent-purple/30 transition-all duration-300 group cursor-default auto-card" data-auto-time={a.time} data-stagger-child>
          <div class="flex items-start gap-3">
            <div class="text-xl shrink-0 mt-0.5 group-hover:scale-110 transition-transform">{a.icon}</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[10px] font-mono font-bold text-accent-cyan">{a.time}</span>
                <span class={`text-[9px] font-mono px-1.5 py-0.5 rounded ${a.model === 'pro' ? 'bg-accent-purple/15 text-accent-purple' : 'bg-accent-cyan/15 text-accent-cyan'}`}>
                  {a.model === 'pro' ? 'MiMo-Pro' : 'MiMo-Flash'}
                </span>
              </div>
              <h3 class="text-xs font-semibold text-text-primary">{a.title}</h3>
              <p class="text-[11px] text-text-muted mt-0.5">{a.desc}</p>
              <span class="text-[9px] font-mono text-accent-green mt-1 inline-block">{a.cost}/run</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Weekly jobs -->
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
      {weeklyJobs.map((j) => (
        <div class="glass-card p-3 border-dashed border-border-glass hover:border-accent-cyan/30 transition-all duration-300">
          <div class="flex items-center gap-3">
            <span class="text-lg">{j.icon}</span>
            <div>
              <div class="flex items-center gap-2">
                <span class="text-[10px] font-mono text-accent-cyan">{j.day} · {j.time}</span>
                <span class="text-[9px] font-mono px-1.5 py-0.5 rounded bg-white/5 text-text-muted">wöchentlich</span>
              </div>
              <h3 class="text-xs font-semibold text-text-primary">{j.title}</h3>
              <p class="text-[11px] text-text-muted">{j.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Daily total -->
    <div class="mt-6 text-center">
      <span class="text-xs font-mono text-text-muted">Tägliche Gesamtkosten: </span>
      <span class="text-xs font-mono text-accent-green font-bold">~$0.09</span>
      <span class="text-xs font-mono text-text-muted"> · 100% automatisiert · 0 manuelle Eingriffe</span>
    </div>
  </div>
</section>

<script>
  // Highlight current/next automation + update time progress
  function updateTimeline() {
    const now = new Date()
    const minutes = now.getHours() * 60 + now.getMinutes()
    const pct = (minutes / 1440) * 100

    // Time progress bar
    const bar = document.getElementById('time-progress')
    if (bar) bar.style.width = `${pct}%`

    // Find next automation
    const cards = document.querySelectorAll<HTMLElement>('[data-auto-time]')
    let nextTime = ''
    let foundNext = false

    cards.forEach(card => {
      const t = card.dataset.autoTime || ''
      const [h, m] = t.split(':').map(Number)
      const cardMin = h * 60 + m

      // Highlight if within 30min window
      if (Math.abs(cardMin - minutes) < 30) {
        card.classList.add('border-accent-green/40')
        const dot = card.querySelector('.w-3')
        if (dot) dot.classList.add('bg-accent-green', 'shadow-[0_0_12px_rgba(126,207,192,0.6)]')
      }

      if (!foundNext && cardMin > minutes) {
        nextTime = t
        foundNext = true
      }
    })

    if (!nextTime) nextTime = '03:00 (morgen)'

    const el = document.getElementById('next-auto-time')
    if (el) {
      if (typeof nextTime === 'string' && nextTime.includes('morgen')) {
        el.textContent = nextTime
      } else {
        const [nh, nm] = nextTime.split(':').map(Number)
        const diff = (nh * 60 + nm) - minutes
        const diffH = Math.floor(diff / 60)
        const diffM = diff % 60
        el.textContent = `${nextTime} (in ${diffH > 0 ? diffH + 'h ' : ''}${diffM}min)`
      }
    }
  }

  updateTimeline()
  setInterval(updateTimeline, 60_000)
</script>
