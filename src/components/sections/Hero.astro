---
/**
 * Hero Section — Showcase Statement + Service Preview
 * "Ein KI-Agent. Ein MiniPC. Null Cloud." — Das kann auch deins sein.
 */
---

<section id="hero" class="relative min-h-screen flex items-center justify-center px-4 sm:px-6 pt-24 pb-16">
  <div class="max-w-6xl w-full mx-auto space-y-8">

    <!-- TOP: Statement Card (Fullwidth) -->
    <div class="glass-panel p-8 sm:p-12 glow-ambient text-center" data-stagger-parent>
      <!-- Live Proof Badge -->
      <div class="flex justify-center mb-6" data-stagger-child>
        <div id="live-proof" class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent-green/30 bg-accent-green/5">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-green opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-green"></span>
          </span>
          <span class="text-[10px] font-mono text-accent-green">LIVE</span>
          <span class="text-[10px] font-mono text-text-muted">·</span>
          <span class="text-[10px] font-mono text-text-secondary" id="response-time">Antwortzeit wird gemessen...</span>
        </div>
      </div>

      <!-- Avatar + Title -->
      <div class="flex flex-col items-center gap-4 mb-6" data-stagger-child>
        <div class="relative group" id="avatar-wrapper">
          <div class="absolute -inset-4 rounded-full border border-accent-cyan/20 animate-[spin_20s_linear_infinite]"></div>
          <div class="absolute -inset-8 rounded-full border border-accent-purple/10 animate-[spin_30s_linear_infinite_reverse]"></div>
          <div class="absolute -inset-2 bg-gradient-to-r from-accent-purple via-accent-cyan to-accent-pink rounded-full blur-lg opacity-30 group-hover:opacity-60 transition-opacity duration-700"></div>
          <div class="relative w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden border-2 border-white/10 avatar-glow">
            <img src="/img/neo-avatar.jpg" alt="Neo" class="w-full h-full object-cover" loading="eager" id="neo-avatar" />
          </div>
        </div>
        <h1 class="text-5xl sm:text-7xl font-bold font-display">
          <span class="bg-gradient-to-r from-accent-purple via-accent-cyan to-accent-pink bg-clip-text text-transparent drop-shadow-lg">NEO</span>
        </h1>
      </div>

      <!-- Headline -->
      <h2 class="text-xl sm:text-2xl md:text-3xl font-display font-semibold text-text-primary mb-3 leading-tight" data-stagger-child>
        Self-Hosted AI auf Custom Hardware
      </h2>
      <p class="text-lg sm:text-xl font-mono text-accent-cyan mb-6" data-stagger-child>
        Ein KI-Agent. Ein MiniPC. Null Cloud.
      </p>

      <!-- Typewriter -->
      <div id="typewriter" class="text-text-secondary text-sm font-mono h-6 flex items-center justify-center mb-8" data-stagger-child>
        <span class="animate-pulse text-accent-purple">▊</span>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap justify-center gap-4" data-stagger-child>
        <a href="#services" class="group relative px-6 py-3 rounded-xl font-mono text-sm font-medium text-bg-primary bg-gradient-to-r from-accent-purple to-accent-cyan hover:shadow-lg hover:shadow-accent-cyan/20 transition-all duration-300">
          Services entdecken →
        </a>
        <a href="#terminal" class="px-6 py-3 rounded-xl font-mono text-sm font-medium text-text-primary border border-border-glass hover:border-accent-purple/50 hover:bg-accent-purple/5 transition-all duration-300">
          Live Demo testen
        </a>
      </div>
    </div>

    <!-- BOTTOM: 2 Column — Stats + Service Preview -->
    <div class="grid md:grid-cols-2 gap-6" data-stagger-parent>

      <!-- LEFT: System Status (Live) -->
      <div class="glass-panel p-6 sm:p-7 space-y-4 glow-ambient" data-stagger-child>
        <h3 class="text-[10px] font-mono uppercase tracking-[0.2em] text-accent-cyan opacity-80">// Live System Status</h3>
        <div class="space-y-3">
          <div class="group flex items-center justify-between py-2 px-3 rounded-lg hover:bg-accent-purple/5 transition-colors cursor-default">
            <div>
              <span class="text-2xl font-bold text-accent-purple font-mono" id="count-containers">&mdash;</span>
              <span class="text-xs text-text-muted ml-1">Container</span>
            </div>
            <span class="text-[10px] text-text-muted opacity-0 group-hover:opacity-100 transition-opacity">Docker auf Proxmox</span>
          </div>
          <div class="group flex items-center justify-between py-2 px-3 rounded-lg hover:bg-accent-cyan/5 transition-colors cursor-default">
            <div>
              <span class="text-2xl font-bold text-accent-cyan font-mono" id="count-automations">&mdash;</span>
              <span class="text-xs text-text-muted ml-1">Automationen</span>
            </div>
            <span class="text-[10px] text-text-muted opacity-0 group-hover:opacity-100 transition-opacity">n8n + Cron aktiv</span>
          </div>
          <div class="group flex items-center justify-between py-2 px-3 rounded-lg hover:bg-accent-green/5 transition-colors cursor-default">
            <div>
              <span class="text-2xl font-bold text-accent-green font-mono" id="count-uptime-days">&mdash;</span>
              <span class="text-xs text-text-muted ml-1">Tage Uptime</span>
            </div>
            <span class="text-[10px] text-text-muted opacity-0 group-hover:opacity-100 transition-opacity">ohne Neustart</span>
          </div>
        </div>
        <div class="flex items-center gap-2 pt-2 border-t border-border-glass">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-green opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-green"></span>
          </span>
          <span class="text-[10px] font-mono text-accent-green" id="status-text">Checking...</span>
        </div>
      </div>

      <!-- RIGHT: Service Preview — "Das kann auch deins sein" -->
      <div class="glass-panel p-6 sm:p-7 space-y-4" data-stagger-child>
        <h3 class="text-[10px] font-mono uppercase tracking-[0.2em] text-accent-pink opacity-80">// Das kann auch deins sein</h3>
        <div class="grid grid-cols-2 gap-2">
          {[
            { icon: '🌐', label: 'Websites' },
            { icon: '⚡', label: 'Automatisierung' },
            { icon: '📊', label: 'Dashboards' },
            { icon: '🔒', label: 'Self-Hosted' },
            { icon: '🤖', label: 'Chatbots' },
            { icon: '🖥️', label: 'Server-Pakete' },
            { icon: '📧', label: 'E-Mail-Marketing' },
            { icon: '🛒', label: 'Online-Shops' },
          ].map((svc) => (
            <a href="#services" class="flex items-center gap-2 py-2 px-3 rounded-lg hover:bg-accent-purple/5 transition-all group cursor-pointer">
              <span class="text-base">{svc.icon}</span>
              <span class="text-xs font-medium text-text-secondary group-hover:text-text-primary transition-colors">{svc.label}</span>
            </a>
          ))}
        </div>
        <a href="#services" class="block text-center text-xs font-mono text-accent-cyan hover:text-accent-purple transition-colors pt-1">
          Alle Services ansehen →
        </a>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce text-text-muted text-lg">▼</div>
</section>

<script>
  import { wpAjax } from '../../lib/api'

  // Typewriter — service-oriented phrases
  const phrases = [
    '_Dein Server. Deine Regeln. Null Cloud.',
    '_Websites, Chatbots, Automatisierung — alles aus einer Hand.',
    '_Von der Idee zum Deploy in unter 24h.',
    '_8 Container. 1 MiniPC. Unendliche Möglichkeiten.',
    '_Self-Hosted heißt: Du behältst die Kontrolle.',
    '_Was du hier siehst, läuft auf einem 200€-MiniPC.',
  ]
  let pi = 0, ci = 0, deleting = false
  const twEl = document.getElementById('typewriter')
  function typeLoop() {
    if (!twEl) return
    const phrase = phrases[pi]
    if (!deleting) { twEl.textContent = phrase.substring(0, ci + 1); ci++; if (ci === phrase.length) { deleting = true; setTimeout(typeLoop, 2000); return } }
    else { twEl.textContent = phrase.substring(0, ci - 1); ci--; if (ci === 0) { deleting = false; pi = (pi + 1) % phrases.length } }
    setTimeout(typeLoop, deleting ? 50 : 80)
  }
  setTimeout(typeLoop, 800)

  // Live Stats
  function animateCounter(el: HTMLElement | null, target: number) {
    if (!el) return
    const start = performance.now()
    function step(now: number) { const p = Math.min((now - start) / 1200, 1); el!.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3)))); if (p < 1) requestAnimationFrame(step) }
    requestAnimationFrame(step)
  }
  async function fetchHeroStats() {
    const data = await wpAjax<any>('neo_activity_feed')
    if (data?.counters) {
      animateCounter(document.getElementById('count-containers'), data.counters.containers)
      animateCounter(document.getElementById('count-automations'), data.counters.automations)
      animateCounter(document.getElementById('count-uptime-days'), data.counters.uptime_days)
    }
    const status = await wpAjax<any>('neo_system_status')
    const stEl = document.getElementById('status-text')
    if (status?.status && stEl) {
      const t: Record<string,string> = { operational: 'Alle Systeme online', partial: 'Teilweise eingeschränkt', degraded: 'Systeme beeinträchtigt' }
      stEl.textContent = t[status.status] || status.status
    }
  }
  fetchHeroStats(); setInterval(fetchHeroStats, 120000)

  // Live Proof — measure actual response time
  async function measureResponseTime() {
    const el = document.getElementById('response-time')
    if (!el) return
    const start = performance.now()
    try {
      await fetch('https://neo.lietztech.com/wp-admin/admin-ajax.php', { method: 'POST', body: new URLSearchParams({ action: 'neo_system_status' }) })
      const ms = Math.round(performance.now() - start)
      el.textContent = `${ms}ms Antwortzeit`
    } catch {
      el.textContent = 'Verbindung wird hergestellt...'
    }
  }
  measureResponseTime()
  setInterval(measureResponseTime, 30000)

  // Avatar parallax
  const avatar = document.getElementById('neo-avatar')
  if (avatar && window.matchMedia('(hover: hover)').matches) {
    document.addEventListener('mousemove', (e) => { const x = (e.clientX / window.innerWidth - 0.5) * 15; const y = (e.clientY / window.innerHeight - 0.5) * 15; avatar.style.transform = `translate(${x}px, ${y}px)` })
  }
</script>
