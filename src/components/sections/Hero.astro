---
/**
 * Hero Section — Full viewport intro with typewriter, stats, and avatar
 */
---

<section id="hero" class="relative min-h-screen flex items-center justify-center px-6 pt-20" data-animate>
  <div class="max-w-7xl w-full mx-auto grid md:grid-cols-3 gap-6">

    <!-- Panel 1: Live Stats -->
    <div class="glass-card p-6 flex flex-col gap-4" data-stagger-child>
      <h3 class="text-xs font-mono uppercase tracking-widest text-accent-cyan">// System Status</h3>
      <div class="grid grid-cols-2 gap-3">
        <div class="text-center">
          <div class="text-2xl font-bold text-accent-purple" data-count="42">42</div>
          <div class="text-xs text-text-muted">Services</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-accent-cyan" data-count="99">99</div>
          <div class="text-xs text-text-muted">Uptime %</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-accent-green" data-count="12">12</div>
          <div class="text-xs text-text-muted">GB RAM</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-accent-pink" data-count="7">7</div>
          <div class="text-xs text-text-muted">Docker</div>
        </div>
      </div>
      <div class="flex items-center gap-2 mt-2">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-green opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-green"></span>
        </span>
        <span class="text-xs font-mono text-accent-green">ALL SYSTEMS ONLINE</span>
      </div>
    </div>

    <!-- Panel 2: Avatar + Name -->
    <div class="glass-card p-8 flex flex-col items-center justify-center text-center gap-4" data-stagger-child>
      <div class="relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-accent-purple via-accent-cyan to-accent-pink rounded-full blur-md opacity-60 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative w-28 h-28 rounded-full overflow-hidden border-2 border-accent-purple/30">
          <div class="w-full h-full bg-gradient-to-br from-accent-purple/20 to-accent-cyan/20 flex items-center justify-center text-4xl">
            🤖
          </div>
        </div>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold font-display">
        <span class="bg-gradient-to-r from-accent-purple via-accent-cyan to-accent-pink bg-clip-text text-transparent">
          NEO
        </span>
      </h1>
      <p class="text-text-secondary text-sm max-w-[250px]">
        HomeLab Engineer · KI-Enthusiast · Digital Architect
      </p>
      <div class="flex gap-2 flex-wrap justify-center">
        <span class="px-2 py-0.5 text-[10px] font-mono rounded-full border border-accent-purple/30 text-accent-purple">self-hosted</span>
        <span class="px-2 py-0.5 text-[10px] font-mono rounded-full border border-accent-cyan/30 text-accent-cyan">proxmox</span>
        <span class="px-2 py-0.5 text-[10px] font-mono rounded-full border border-accent-pink/30 text-accent-pink">AI-native</span>
      </div>
    </div>

    <!-- Panel 3: Typewriter Terminal -->
    <div class="glass-card p-6 flex flex-col gap-3 font-mono text-sm" data-stagger-child>
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-accent-red"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
        <span class="w-3 h-3 rounded-full bg-accent-green"></span>
        <span class="ml-2 text-text-muted text-xs">neo@homelab:~$</span>
      </div>
      <div id="typewriter" class="text-accent-green min-h-[120px]">
        <span class="animate-pulse">▊</span>
      </div>
    </div>

  </div>
</section>

<script>
  const lines = [
    '> neofetch',
    '  OS: Proxmox VE 9.1.6',
    '  Host: ACE Magic S (Intel N97)',
    '  RAM: 12GB / 16GB',
    '  VMs: 1 | LXC: 3',
    '  Docker: 8 Container',
    '> status --all',
    '  ✅ OpenClaw Gateway ... ONLINE',
    '  ✅ Paperless-ngx ..... ONLINE',
    '  ✅ SearXNG ........... ONLINE',
    '  ✅ Caddy Reverse Proxy ONLINE',
    '  ✅ Gotify Notifications ONLINE',
    '> echo "Welcome to the machine."',
  ]

  const container = document.getElementById('typewriter')
  if (container) {
    let lineIdx = 0
    let charIdx = 0
    container.innerHTML = ''

    function type() {
      if (lineIdx >= lines.length) {
        container!.innerHTML += '<span class="animate-pulse">▊</span>'
        return
      }

      const line = lines[lineIdx]
      if (charIdx === 0) {
        const div = document.createElement('div')
        div.className = line.startsWith('>') ? 'text-accent-cyan' : 'text-text-secondary'
        container!.appendChild(div)
      }

      const currentDiv = container!.lastElementChild as HTMLElement
      if (charIdx < line.length) {
        currentDiv.textContent = line.slice(0, charIdx + 1)
        charIdx++
        setTimeout(type, 20 + Math.random() * 30)
      } else {
        charIdx = 0
        lineIdx++
        setTimeout(type, line.startsWith('>') ? 400 : 100)
      }
    }

    // Start typing after short delay
    setTimeout(type, 800)
  }
</script>
