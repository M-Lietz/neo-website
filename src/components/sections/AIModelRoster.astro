---
/**
 * AIModelRoster — Die KI-Modell-Flotte mit Fallback-Chain
 * Zeigt alle 11 Modelle, Provider, Kosten, Status
 */
const models = [
  { name: 'MiMo-V2-Pro', provider: 'Xiaomi / OpenRouter', cost: '$1 / $3', context: '1M', role: 'Haupt-Agent', status: 'primary', badge: '⚡ PRIMARY' },
  { name: 'MiMo-V2-Flash', provider: 'Xiaomi / OpenRouter', cost: '$0.09 / $0.29', context: '1M', role: 'Sub-Agents & Cron-Jobs', status: 'active', badge: '🔄 FALLBACK' },
  { name: 'MiMo-V2-Omni', provider: 'Xiaomi / OpenRouter', cost: '$0.40 / $2', context: '1M', role: 'Multimodal (Bild + Text)', status: 'active', badge: '👁️ VISION' },
  { name: 'Claude Opus 4.6', provider: 'Anthropic', cost: '$5 / $25', context: '200K', role: 'Premium-Fallback', status: 'standby', badge: '🧠 PREMIUM' },
  { name: 'Claude Sonnet 4.6', provider: 'Anthropic', cost: '$3 / $15', context: '200K', role: 'Copilot IDE', status: 'standby', badge: '' },
  { name: 'Gemini 2.5 Flash', provider: 'Google Vertex', cost: '$0 FREE', context: '1M', role: 'Budget-Backup', status: 'active', badge: '🆓 FREE' },
  { name: 'DeepSeek V3.2', provider: 'DeepSeek', cost: '$0.25 / $0.40', context: '128K', role: 'Open-Source Fallback', status: 'standby', badge: '' },
  { name: 'Grok 4.1', provider: 'xAI', cost: '$0.20 / $0.50', context: '2M', role: 'Long-Context Tasks', status: 'standby', badge: '📐 2M CTX' },
  { name: 'Kimi K2.5', provider: 'Moonshot', cost: '$0.45 / $2.20', context: '128K', role: 'Schnelle Inferenz', status: 'standby', badge: '' },
  { name: 'Qwen3 235B', provider: 'Alibaba', cost: '$0.14 / $0.60', context: '128K', role: 'Budget-Modell', status: 'standby', badge: '' },
]

const fallbackChain = ['MiMo-V2-Pro', 'MiMo-V2-Flash', 'Gemini 2.5 Flash', 'Claude Opus 4.6']

const statusColors: Record<string, { dot: string; bg: string; label: string }> = {
  primary: { dot: 'bg-accent-green', bg: 'border-accent-green/30', label: 'Active' },
  active: { dot: 'bg-accent-cyan', bg: 'border-accent-cyan/20', label: 'Online' },
  standby: { dot: 'bg-yellow-500', bg: 'border-transparent', label: 'Standby' },
}
---

<section id="ai-models" class="px-4 sm:px-6 py-16" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-1 max-w-5xl mx-auto title-glow">
    <span class="title-glow-line"></span>// AI Model Roster
  </h2>
  <p class="text-text-secondary text-sm max-w-5xl mx-auto mb-2 pl-[52px]">
    {models.length} Modelle, 6 Provider, eine intelligente Fallback-Chain.
  </p>
  <p class="text-text-muted text-xs max-w-5xl mx-auto mb-8 pl-[52px] font-mono">
    Nicht ein LLM — ein ganzes Routing-System. Automatisch das beste Modell zum besten Preis.
  </p>

  <!-- Fallback Chain Visual -->
  <div class="max-w-5xl mx-auto mb-8" data-animate>
    <div class="glass-panel p-4">
      <div class="text-[10px] font-mono text-text-muted mb-3">FALLBACK CHAIN</div>
      <div class="flex flex-wrap items-center gap-2" id="fallback-chain">
        {fallbackChain.map((name, i) => (
          <div class="flex items-center gap-2">
            <div class="fallback-node glass-card px-3 py-2 text-xs font-mono text-text-primary hover:border-accent-purple/40 transition-all duration-300 cursor-default" data-chain-idx={i}>
              <span class={`inline-block w-2 h-2 rounded-full mr-2 ${i === 0 ? 'bg-accent-green animate-pulse' : i < 3 ? 'bg-accent-cyan' : 'bg-yellow-500'}`}></span>
              {name}
            </div>
            {i < fallbackChain.length - 1 && (
              <svg width="20" height="12" viewBox="0 0 20 12" class="text-accent-purple/50 shrink-0 chain-arrow">
                <path d="M0 6h16M12 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" fill="none" />
              </svg>
            )}
          </div>
        ))}
      </div>
      <p class="text-[10px] font-mono text-text-muted mt-3">
        Wenn ein Modell nicht antwortet, springt automatisch das nächste ein. Kein Ausfall, kein manueller Eingriff.
      </p>
    </div>
  </div>

  <!-- Model Grid -->
  <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" data-stagger-parent>
    {models.map((m) => {
      const s = statusColors[m.status]
      return (
        <div class={`glass-card p-4 ${s.bg} hover:border-accent-purple/30 transition-all duration-300 group cursor-default model-card`} data-stagger-child data-model={m.name}>
          <!-- Header -->
          <div class="flex items-start justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class={`w-2 h-2 rounded-full ${s.dot} ${m.status === 'primary' ? 'animate-pulse' : ''}`}></span>
              <span class="text-[10px] font-mono text-text-muted">{s.label}</span>
            </div>
            {m.badge && (
              <span class="text-[9px] font-mono px-1.5 py-0.5 rounded bg-accent-purple/10 text-accent-purple">{m.badge}</span>
            )}
          </div>

          <!-- Name + Provider -->
          <h3 class="text-sm font-semibold text-text-primary mb-0.5 group-hover:text-accent-cyan transition-colors">{m.name}</h3>
          <p class="text-[10px] font-mono text-text-muted mb-3">{m.provider}</p>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-2 text-[10px] font-mono">
            <div>
              <span class="text-text-muted block">Kosten</span>
              <span class={`text-text-secondary ${m.cost.includes('FREE') ? 'text-accent-green font-bold' : ''}`}>{m.cost}</span>
            </div>
            <div>
              <span class="text-text-muted block">Context</span>
              <span class="text-text-secondary">{m.context}</span>
            </div>
          </div>

          <!-- Role -->
          <div class="mt-3 pt-2 border-t border-white/5">
            <span class="text-[10px] text-text-muted">{m.role}</span>
          </div>
        </div>
      )
    })}
  </div>

  <!-- Summary -->
  <div class="max-w-5xl mx-auto mt-6 text-center">
    <span class="text-xs font-mono text-text-muted">Durchschnittliche Kosten: </span>
    <span class="text-xs font-mono text-accent-green font-bold">~$0.12/Tag</span>
    <span class="text-xs font-mono text-text-muted"> · Kein Vendor Lock-in · Jederzeit wechselbar</span>
  </div>
</section>

<script>
  // Animate fallback chain demo on click
  const nodes = document.querySelectorAll<HTMLElement>('.fallback-node')
  const arrows = document.querySelectorAll<HTMLElement>('.chain-arrow')

  let demoRunning = false
  document.getElementById('fallback-chain')?.addEventListener('click', async () => {
    if (demoRunning) return
    demoRunning = true

    // Simulate: first model "fails", chain kicks in
    for (let i = 0; i < nodes.length; i++) {
      nodes[i].classList.add('border-accent-purple/60', 'scale-105')
      nodes[i].style.boxShadow = '0 0 20px rgba(126,180,245,0.3)'

      if (i > 0) {
        // Previous "failed"
        nodes[i - 1].classList.remove('border-accent-purple/60', 'scale-105')
        nodes[i - 1].style.boxShadow = ''
        nodes[i - 1].style.opacity = '0.4'
        if (arrows[i - 1]) arrows[i - 1].classList.add('text-accent-purple')
      }

      await new Promise(r => setTimeout(r, 800))
    }

    // Last one "succeeds"
    nodes[nodes.length - 1].classList.add('border-accent-green/60')
    nodes[nodes.length - 1].style.boxShadow = '0 0 20px rgba(126,207,192,0.3)'

    // Reset after 2s
    await new Promise(r => setTimeout(r, 2000))
    nodes.forEach(n => {
      n.classList.remove('border-accent-purple/60', 'border-accent-green/60', 'scale-105')
      n.style.boxShadow = ''
      n.style.opacity = ''
    })
    arrows.forEach(a => a.classList.remove('text-accent-purple'))
    demoRunning = false
  })
</script>
