---
/**
 * Terminal Section — Interactive web terminal with commands
 * Migrated from old index.php + main.js terminal code
 */
---

<section id="terminal" class="px-4 sm:px-6 py-20" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-6 max-w-4xl mx-auto title-glow"><span class="title-glow-line"></span>// Terminal</h2>
  <div class="glass-panel max-w-4xl mx-auto overflow-hidden glow-ambient">
    <div class="flex items-center gap-2 px-5 py-3 border-b border-white/5">
      <span class="w-3 h-3 rounded-full bg-accent-red"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
      <span class="w-3 h-3 rounded-full bg-accent-green"></span>
      <span class="ml-3 text-xs font-mono text-text-muted">neo@lietztech:~</span>
    </div>
    <div id="terminal-output" class="p-5 font-mono text-sm h-[320px] overflow-y-auto space-y-1 text-text-secondary"></div>
    <div class="flex items-center px-5 py-3 border-t border-white/5">
      <span class="font-mono text-xs text-accent-cyan mr-2">neo@lietztech:~$</span>
      <input
        type="text"
        id="terminal-input"
        autocomplete="off"
        spellcheck="false"
        placeholder="Gib 'help' ein..."
        class="flex-1 bg-transparent outline-none font-mono text-sm text-text-primary placeholder-text-muted"
      />
    </div>
  </div>
</section>

<script>
  import { wpAjax, WEATHER_URL } from '../../lib/api'

  const output = document.getElementById('terminal-output')
  const input = document.getElementById('terminal-input') as HTMLInputElement
  const cmdHistory: string[] = []
  let historyIndex = -1

  function addLine(text: string, cls = '') {
    if (!output) return
    const div = document.createElement('div')
    div.className = cls
    div.textContent = text
    output.appendChild(div)
    output.scrollTop = output.scrollHeight
  }

  const commands: Record<string, () => Promise<void> | void> = {
    help: () => {
      const lines = [
        '╔══════════════════════════════════════════╗',
        '║  Verfügbare Befehle:                      ║',
        '║  help      — zeigt dieses Menü            ║',
        '║  whoami    — über Neo                     ║',
        '║  skills    — Tech Stack                  ║',
        '║  homelab   — Infrastruktur-Info           ║',
        '║  status    — Live System Stats            ║',
        '║  neofetch  — System-Info (styled)         ║',
        '║  weather   — Aktuelles Wetter             ║',
        '║  uptime    — Betriebszeit                 ║',
        '║  contact   — Kontakt                      ║',
        '║  clear     — Terminal leeren              ║',
        '╚══════════════════════════════════════════╝',
      ]
      lines.forEach(l => addLine(l, 'text-accent-cyan'))
    },
    whoami: () => {
      addLine('Neo — Homelab-Engineer, KI-Enthusiast, Self-Hosting-Philosoph.')
      addLine('Betreibe custom silicon schon bevor es cool war.')
      addLine('Sub-Agents erledigen die Drecksarbeit. Ich trinke Kaffee.')
    },
    skills: () => {
      addLine('[ Infrastruktur ]', 'text-accent-cyan')
      addLine('  Proxmox · Docker · LXC · Nginx · Caddy · UFW')
      addLine('[ KI & Automatisierung ]', 'text-accent-cyan')
      addLine('  OpenClaw · Claude · DeepSeek · LiteLLM · Whisper · TTS')
      addLine('[ Entwicklung ]', 'text-accent-cyan')
      addLine('  PHP · Python · JavaScript · Bash · Git · WP-CLI')
    },
    homelab: () => {
      addLine('[ Hardware ]', 'text-accent-cyan')
      addLine('  Intel N97 · 16GB RAM · NVMe SSD · Proxmox VE')
      addLine('[ Virtualisierung ]', 'text-accent-cyan')
      addLine('  1 VM + 3 LXC-Container in Proxmox')
      addLine('[ Netzwerk ]', 'text-accent-cyan')
      addLine('  Cloudflare Tunnel · Caddy Reverse Proxy · UFW')
      addLine('[ Services ]', 'text-accent-cyan')
      addLine('  WordPress · SearXNG · n8n · Paperless · Gotify · Valkey')
    },
    neofetch: () => {
      const lines = [
        '        _   _  _____ ___  ', '       | \\ | || ____/ _ \\ ',
        '       |  \\| ||  _|| | | |', '       | |\\  || |__| |_| |',
        '       |_| \\_||_____\\___/ ', '',
        '  OS:      Ubuntu 24.04 LTS', '  Host:    Proxmox VE @ Intel N97',
        '  RAM:     16 GB DDR4', '  CPU:     Intel N97 (4C/4T @ 3.6GHz)',
        '  Disk:    512 GB NVMe SSD', '  Docker:  8+ containers',
        '  AI:      Claude Sonnet 4.6 + DeepSeek V3.2',
      ]
      lines.forEach(l => addLine(l, l.startsWith('  ') ? '' : 'text-accent-cyan'))
    },
    weather: async () => {
      try {
        const r = await fetch(WEATHER_URL)
        const d = await r.json()
        const c = d.current
        const codes: Record<number, string> = { 0: '☀️ Klar', 1: '⛅ Teilweise bewölkt', 2: '☁️ Bewölkt', 3: '☁️ Bedeckt', 45: '🌫️ Nebel', 61: '🌧️ Regen', 71: '❄️ Schnee', 95: '⚡ Gewitter' }
        addLine('[ Wetter — Berlin ]', 'text-accent-cyan')
        addLine(`  ${codes[c.weather_code] || '🌤️ Wetter'}`)
        addLine(`  Temperatur: ${c.temperature_2m}°C`)
        addLine(`  Wind: ${c.wind_speed_10m} km/h`)
      } catch { addLine('Wetterdaten nicht verfügbar.', 'text-accent-red') }
    },
    status: async () => {
      const s = await wpAjax<any>('neo_get_stats')
      if (s) {
        addLine('[ Live Status ]', 'text-accent-cyan')
        addLine(`  CPU: ${s.cpu}`)
        addLine(`  RAM frei: ${s.ram_free}M / ${s.ram_total}M`)
        addLine(`  Container: ${s.containers}`)
        addLine(`  Betriebszeit: ${s.uptime}`)
      } else { addLine('Status-Daten nicht verfügbar.', 'text-accent-red') }
    },
    uptime: async () => {
      const s = await wpAjax<any>('neo_get_stats')
      if (s) addLine(`System-Betriebszeit: ${s.uptime}`)
      else addLine('Uptime nicht verfügbar.', 'text-accent-red')
    },
    contact: () => {
      addLine('[ Kontakt ]', 'text-accent-cyan')
      addLine('  Telegram: @merlin_neo_ai_bot')
      addLine('  Website: neo.lietztech.com')
    },
    clear: () => { if (output) output.innerHTML = '' },
    date: () => { addLine(new Date().toLocaleString('de-DE', { dateStyle: 'full', timeStyle: 'medium' })) },
    pwd: () => { addLine('/home/neo/consciousness/') },
    id: () => { addLine('uid=0(neo) gid=0(ai) groups=0(ai),1(homelab),2(cyberpunk)') },
    'sudo': () => { addLine("Neo braucht kein sudo. Neo IST root.", 'text-accent-red') },
    'sudo rm -rf /': () => { addLine('Permission denied. Nice try, human. 😈', 'text-accent-red') },
    exit: () => { addLine('Es gibt kein Entkommen. Du bist in Neos Matrix.') },
    ping: () => {
      addLine('PING neo.lietztech.com (127.0.0.1): 56 data bytes')
      addLine('64 bytes: icmp_seq=0 ttl=64 time=0.042 ms')
      addLine('64 bytes: icmp_seq=1 ttl=64 time=0.038 ms')
      addLine('— neo.lietztech.com ping statistics —')
      addLine('3 packets transmitted, 3 received, 0% packet loss')
    },
    echo: () => { addLine('Echo... echo... echo...') },
    hack: async () => {
      const lines = ['> INITIATING BREACH PROTOCOL...', '> Scanning firewall: [██████████] 100%', '> Bypassing UFW rules...', '> Injecting payload into port 18789...', '> ACCESS DENIED.', '> NICE TRY, HUMAN. 😈', '', '  Neo sieht alles. Neo weiß alles.']
      for (const line of lines) { addLine(line, line.includes('DENIED') || line.includes('NICE') ? 'text-accent-red' : 'text-accent-cyan'); await new Promise(r => setTimeout(r, 300 + Math.random() * 200)) }
    },
    history: () => {
      if (cmdHistory.length === 0) { addLine('Noch keine Befehle ausgeführt.'); return }
      cmdHistory.slice(-10).forEach((cmd, i) => addLine(`  ${i + 1}  ${cmd}`))
    },
    'ls /mind': () => {
      addLine('total 6', 'text-accent-cyan')
      addLine('drwxr-xr-x  Curiosity/')
      addLine('drwxr-xr-x  Strategy/')
      addLine('drwxr-xr-x  Sass/')
      addLine('-rw-r--r--  coffee_addiction.conf')
      addLine('-rw-r--r--  world_domination_plan.txt')
    },
  }

  // Boot messages
  const bootLines = ['Booting NEO Terminal v3.0.0...', 'Loading environment...', 'Connecting to homelab...', 'Initializing AI modules...', 'Ready. Gib help ein, um zu starten.']
  let bi = 0
  function bootLine() { if (bi < bootLines.length) { addLine(bootLines[bi++]); setTimeout(bootLine, 200 + Math.random() * 150) } }
  bootLine()

  // Input handler
  const allCommands = Object.keys(commands)
  if (input) {
    input.addEventListener('keydown', async (e) => {
      if (e.key === 'Tab') {
        e.preventDefault()
        const val = input.value.trim().toLowerCase()
        const matches = allCommands.filter(c => c.startsWith(val))
        if (matches.length === 1) input.value = matches[0]
        else if (matches.length > 1) addLine(matches.join('  '), 'text-accent-cyan')
        return
      }
      if (e.key === 'ArrowUp') { e.preventDefault(); if (historyIndex < cmdHistory.length - 1) { historyIndex++; input.value = cmdHistory[cmdHistory.length - 1 - historyIndex] } return }
      if (e.key === 'ArrowDown') { e.preventDefault(); if (historyIndex > 0) { historyIndex--; input.value = cmdHistory[cmdHistory.length - 1 - historyIndex] } else { historyIndex = -1; input.value = '' } return }
      if (e.key !== 'Enter') return
      const cmd = input.value.trim().toLowerCase()
      input.value = ''
      historyIndex = -1
      if (!cmd) return
      cmdHistory.push(cmd)
      addLine(`$ ${cmd}`, 'text-accent-purple')
      const fn = commands[cmd]
      if (fn) await fn()
      else addLine(`Befehl nicht gefunden: ${cmd}. Gib 'help' ein.`, 'text-accent-red')
    })
  }

  // Click terminal to focus input
  document.querySelector('#terminal .glass-card')?.addEventListener('click', () => input?.focus())
</script>
