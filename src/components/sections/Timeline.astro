---
/**
 * Timeline Section — Merlins Weg vom Quereinsteiger zum Homelab
 * Klick auf Meilenstein → expandiert "Was ich gelernt habe"
 */
const milestones = [
  { date: 'Ende 2024', title: 'Der Anfang', desc: 'IT-Umschulung gestartet. Erster eigener Linux-Server aufgesetzt. Alles war neu.',
    learnings: ['Linux-Basics: Dateisystem, Berechtigungen, systemd', 'Netzwerk-Grundlagen: IP, DNS, SSH, Firewall', 'Erster Kontakt mit der Shell — Angst vor der Kommandozeile verloren'] },
  { date: 'März 2025', title: 'Homelab geboren', desc: 'ACE Magic MiniPC gekauft, Proxmox installiert, erste VMs und Container erstellt.',
    learnings: ['Hypervisor-Konzepte: VMs vs Container, Ressourcen-Planung', 'Proxmox VE: Cluster, Backup, Storage, Netzwerk-Bridges', 'Hardware-Entscheidungen: Warum ein €200-MiniPC reicht'] },
  { date: 'April 2025', title: 'KI trifft Homelab', desc: 'OpenClaw Gateway gebaut — eigener KI-Agent mit Claude + DeepSeek, komplett self-hosted.',
    learnings: ['Python: API-Design, Async, Error Handling', 'LLM-Konzepte: Prompts, Tokens, Context Windows, Fallback-Chains', 'API-Proxy-Architektur: LiteLLM als Model-Router'] },
  { date: 'Mai 2025', title: 'Docker-Stack wächst', desc: 'Paperless, SearXNG, Gotify, n8n — Service für Service dazugelernt und containerisiert.',
    learnings: ['Docker Compose: Multi-Container, Volumes, Networks', 'Reverse Proxy: Caddy + Auto-TLS + Cloudflare Tunnel', 'Monitoring: Uptime, Logs, Alerts via Gotify'] },
  { date: 'Sommer 2025', title: 'Telegram-Automatisierung', desc: '7 Automationen, Content-Mix, eigener Bot — alles über APIs verbunden, kein Klick-Tool.',
    learnings: ['Telegram Bot API: Inline Keyboards, Callbacks, Webhooks', 'Cron + systemd: 14 automatisierte Jobs, zero Downtime', 'Content-Pipeline: KI-generierte Texte, Bilder, Sprache'] },
  { date: 'Herbst 2025', title: 'Erste Website live', desc: 'neo.lietztech.com mit WordPress, Cyberpunk-Design, Echtzeit-Dashboard. Alles custom.',
    learnings: ['WordPress: Theme-Dev, REST API, Custom Post Types', 'Nginx: Security Headers, Caching, SSL-Konfiguration', 'Web-Design: CSS Grid, Glassmorphism, responsive'] },
  { date: 'März 2026', title: 'Migration auf Astro', desc: 'Kompletter Rewrite: Astro + Tailwind + Three.js. Schneller, sicherer, modularer.',
    learnings: ['Astro: Island-Architektur, Static Site Generation', 'Three.js: WebGL, Shader, Dual-Canvas, Performance', 'DSGVO: Impressum, Datenschutz, lokale Fonts, Security Headers'] },
]
---

<section id="timeline" class="px-4 sm:px-6 py-16" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-3 max-w-4xl mx-auto title-glow"><span class="title-glow-line"></span>// Mein Weg</h2>
  <p class="text-text-secondary text-sm max-w-4xl mx-auto mb-8 pl-[52px]">
    Vom Quereinsteiger zum eigenen Homelab — in unter zwei Jahren. <span class="text-text-muted text-xs">Klick für Details.</span>
  </p>
  <div class="max-w-4xl mx-auto relative">
    <!-- Vertical line -->
    <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-accent-purple via-accent-cyan to-accent-pink"></div>
    <div class="space-y-8">
      {milestones.map((m, i) => (
        <div class={`relative flex items-start gap-6 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`} data-animate>
          <!-- Dot -->
          <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-accent-purple border-2 border-bg-primary -translate-x-1/2 mt-1.5 z-10"></div>
          <!-- Card -->
          <div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:pr-8' : 'md:pl-8'}`}>
            <details class="glass-expand">
              <summary class="glass-card p-4 hover:border-accent-purple/30 transition-colors cursor-pointer">
                <div class="flex-1">
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-mono text-accent-cyan">{m.date}</span>
                    <svg class="expand-chevron w-3.5 h-3.5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </div>
                  <h3 class="text-sm font-semibold text-text-primary mt-1">{m.title}</h3>
                  <p class="text-xs text-text-secondary mt-1">{m.desc}</p>
                </div>
              </summary>
              <div class="expand-content">
                <div class="expand-inner">
                  <div class="px-4 pb-4 pt-2 border-t border-white/5 mt-1 space-y-1.5">
                    <span class="text-[10px] font-mono text-accent-purple uppercase tracking-wider">Was ich gelernt habe:</span>
                    {m.learnings.map(l => (
                      <div class="flex items-start gap-2 text-xs">
                        <span class="text-accent-green mt-0.5 shrink-0">›</span>
                        <span class="text-text-secondary">{l}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </details>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
