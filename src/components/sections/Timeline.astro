---
/**
 * Timeline Section — Project milestones
 * Static data (was WP_Query with fallback in old site)
 */
const milestones = [
  { date: 'März 2025', title: 'Project Neo gestartet', desc: 'Erster Proxmox-Host aufgesetzt, erste VM erstellt.' },
  { date: 'April 2025', title: 'OpenClaw v1 deployed', desc: 'KI-Gateway mit Claude + DeepSeek live auf dem Homelab.' },
  { date: 'Mai 2025', title: 'Docker-Stack komplett', desc: 'Paperless, SearXNG, Gotify, n8n — alles containerisiert.' },
  { date: 'Juni 2025', title: 'Telegram Bot & Channel', desc: '7 Automationen, Content-Mix, Callback-Daemon — das volle Programm.' },
  { date: 'Oktober 2025', title: 'Neo Website Launch', desc: 'Cyberpunk-Design mit Echtzeit-Dashboard und Terminal.' },
  { date: 'März 2026', title: 'Astro Migration', desc: 'Kompletter Rewrite: Astro + Tailwind + Three.js. Schneller, modularer, geiler.' },
]
---

<section id="timeline" class="px-4 sm:px-6 py-16" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-8 max-w-4xl mx-auto title-glow"><span class="title-glow-line"></span>// Timeline</h2>
  <div class="max-w-4xl mx-auto relative">
    <!-- Vertical line -->
    <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-accent-purple via-accent-cyan to-accent-pink"></div>
    <div class="space-y-8">
      {milestones.map((m, i) => (
        <div class={`relative flex items-start gap-6 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`} data-animate>
          <!-- Dot -->
          <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-accent-purple border-2 border-bg-primary -translate-x-1/2 mt-1.5 z-10"></div>
          <!-- Card -->
          <div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:pr-8' : 'md:pl-8'}`}>
            <div class="glass-card p-4 hover:border-accent-purple/30 transition-colors">
              <span class="text-xs font-mono text-accent-cyan">{m.date}</span>
              <h3 class="text-sm font-semibold text-text-primary mt-1">{m.title}</h3>
              <p class="text-xs text-text-secondary mt-1">{m.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
