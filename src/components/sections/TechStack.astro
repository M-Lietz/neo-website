---

<section id="techstack" class="px-4 sm:px-6 py-20" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-3 max-w-6xl mx-auto title-glow"><span class="title-glow-line"></span>// Tech Stack</h2>
  <p class="text-text-secondary text-sm max-w-6xl mx-auto mb-6 pl-[52px]">
    36 Tools, 6 Kategorien — hover für Details.
  </p>
  <div class="max-w-6xl mx-auto grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-stagger-parent>
    {categories.map(cat => (
      <div class="glass-card p-5 hover:border-accent-purple/30 transition-colors group" data-stagger-child>
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">{cat.icon}</span>
          <h3 class={`text-sm font-mono text-${cat.color}`}>{cat.title}</h3>
        </div>
        <div class="flex flex-wrap gap-1.5">
          {cat.items.map(item => (
            <span class="skill-tag px-2 py-0.5 text-xs font-mono rounded bg-white/5 text-text-secondary hover:text-text-primary hover:bg-white/10 transition-colors">
              {item.name}
              <span class="skill-tooltip">{item.tip}</span>
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
