    { name: 'SQL', tip: 'WordPress DB, Paperless-ngx PostgreSQL' },
  ]},
  { title: 'Kommunikation', icon: '📡', color: 'accent-green', items: [
    { name: 'Telegram Bot API', tip: '@merlin_neo_ai_bot — 24/7 Chat + Kanal-Automation' },
    { name: 'Cloudflare Tunnel', tip: 'Zero-Trust Zugang — kein offener Port nötig' },
    { name: 'Gotify Push', tip: 'Echtzeit-Alerts: Container down, Backup fertig' },
