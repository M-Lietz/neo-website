---
/**
 * Achievements Section — 16 badge grid with unlock tracking
 * Uses neo_get_achievements / neo_unlock_achievement AJAX
 */
const badges = [
  { id: 'first_visit', icon: '🏠', title: 'Erster Besuch', desc: 'Willkommen!' },
  { id: 'terminal_used', icon: '💻', title: 'Terminal-Nutzer', desc: 'Einen Befehl ausgeführt' },
  { id: 'help_command', icon: '❓', title: 'Hilfe gesucht', desc: 'help eingegeben' },
  { id: 'matrix_entered', icon: '🟢', title: 'Matrix betreten', desc: 'Konami-Code eingegeben' },
  { id: 'snake_played', icon: '🐍', title: 'Snake Meister', desc: 'Snake im Terminal gespielt' },
  { id: 'five_commands', icon: '⌨️', title: '5 Commands', desc: '5 Terminal-Befehle ausgeführt' },
  { id: 'scroll_bottom', icon: '⬇️', title: 'Bottom Reached', desc: 'Bis ganz unten gescrollt' },
  { id: 'all_sections', icon: '👀', title: 'Alles gesehen', desc: 'Alle Sektionen besucht' },
  { id: 'music_toggle', icon: '🎵', title: 'DJ', desc: 'Musik ein/ausgeschaltet' },
  { id: 'mode_switch', icon: '🔄', title: 'Mode Switch', desc: 'System-Modus gewechselt' },
  { id: 'keyboard_pro', icon: '⚡', title: 'Keyboard Pro', desc: '10 Commands in 1 Min' },
  { id: 'night_owl', icon: '🦉', title: 'Nachteule', desc: 'Nach Mitternacht besucht' },
  { id: 'guestbook_post', icon: '📖', title: 'Gästebuch', desc: 'Einen Eintrag hinterlassen' },
  { id: 'newsletter_sub', icon: '📧', title: 'Abonnent', desc: 'Newsletter abonniert' },
  { id: 'contact_sent', icon: '✉️', title: 'Kontakt', desc: 'Nachricht gesendet' },
  { id: 'konami_code', icon: '🎮', title: 'Konami Code', desc: '↑↑↓↓←→←→BA' },
]
---

<section id="achievements" class="px-4 sm:px-6 py-16" data-animate>
  <h2 class="text-lg font-mono text-accent-cyan mb-6 max-w-5xl mx-auto title-glow"><span class="title-glow-line"></span>// Achievements</h2>
  <div class="max-w-5xl mx-auto grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3" data-stagger-parent>
    {badges.map(b => (
      <div class="glass-card p-3 text-center group achievement-badge opacity-40 grayscale transition-all duration-500"
        data-badge={b.id} data-stagger-child title={b.desc}>
        <div class="text-2xl mb-1 group-hover:scale-110 transition-transform">{b.icon}</div>
        <div class="text-[10px] font-mono text-text-muted leading-tight">{b.title}</div>
      </div>
    ))}
  </div>
  <p class="text-center text-xs font-mono text-text-muted mt-4">
    <span id="achievement-count">0</span> / {badges.length} freigeschaltet
  </p>
</section>

<script>
  import { wpAjax } from '../../lib/api'

  // Global unlock function
  const unlocked = new Set<string>(JSON.parse(localStorage.getItem('neo_achievements') || '[]'))

  function updateUI() {
    document.querySelectorAll('.achievement-badge').forEach(el => {
      const id = (el as HTMLElement).dataset.badge
      if (id && unlocked.has(id)) {
        el.classList.remove('opacity-40', 'grayscale')
        el.classList.add('opacity-100')
      }
    })
    const counter = document.getElementById('achievement-count')
    if (counter) counter.textContent = String(unlocked.size)
  }

  (window as any).unlockAchievement = async (id: string) => {
    if (unlocked.has(id)) return
    unlocked.add(id)
    localStorage.setItem('neo_achievements', JSON.stringify([...unlocked]))
    updateUI()
    wpAjax('neo_unlock_achievement', { achievement: id }).catch(() => {})
  }

  // Auto: first_visit
  ;(window as any).unlockAchievement('first_visit')

  // Night owl
  if (new Date().getHours() >= 0 && new Date().getHours() < 5) {
    ;(window as any).unlockAchievement('night_owl')
  }

  // Scroll bottom
  window.addEventListener('scroll', () => {
    if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 100) {
      ;(window as any).unlockAchievement('scroll_bottom')
    }
  }, { passive: true })

  // Fetch server-side achievements
  async function fetchAchievements() {
    const data = await wpAjax<any>('neo_get_achievements')
    if (data?.unlocked) {
      data.unlocked.forEach((id: string) => unlocked.add(id))
      localStorage.setItem('neo_achievements', JSON.stringify([...unlocked]))
    }
    updateUI()
  }

  fetchAchievements()
</script>
