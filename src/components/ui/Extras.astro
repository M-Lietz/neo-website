---
/**
 * Extras — Boot overlay, Back-to-top, Visitor counter, Konami code, Custom cursor, Built-with badge
 * All the small interactive features and easter eggs
 */
---

<!-- Boot Overlay -->
<div id="boot-overlay" class="fixed inset-0 z-[9999] bg-bg-primary flex items-center justify-center transition-opacity duration-500">
  <div class="text-center">
    <div id="boot-text" class="font-mono text-sm text-accent-cyan space-y-1"></div>
    <div class="mt-4 w-48 h-1 rounded-full bg-white/10 mx-auto overflow-hidden">
      <div id="boot-bar" class="h-full rounded-full bg-accent-purple transition-all duration-300" style="width: 0%"></div>
    </div>
  </div>
</div>

<!-- Back to Top -->
<button id="back-to-top" aria-label="Nach oben scrollen"
  class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full glass-card flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 hover:border-accent-purple/50 text-text-muted hover:text-accent-purple">
  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 15l-6-6-6 6"/></svg>
</button>

<!-- Visitor Counter (footer overlay) -->
<div id="visitor-counter" class="fixed bottom-6 left-6 z-50 text-xs font-mono text-text-muted">
  👁 <span id="visitor-count">—</span>
</div>

<!-- Built-with Badge -->
<div id="built-with" class="fixed bottom-16 left-6 z-50 group cursor-pointer">
  <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-bg-secondary/80 backdrop-blur-sm border border-border-glass text-[10px] font-mono text-text-muted hover:text-text-secondary hover:border-accent-purple/30 transition-all duration-300">
    <span>⚡</span>
    <span>Built with</span>
    <span class="text-accent-purple">Neo Stack</span>
  </div>
  <!-- Expanded tech badge on hover -->
  <div class="absolute bottom-full left-0 mb-2 opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
    <div class="glass-card p-3 text-[10px] font-mono space-y-1 w-48">
      <div class="text-accent-cyan mb-2">Tech Stack dieser Site:</div>
      <div class="text-text-muted">🏗️ Astro v6 + Three.js</div>
      <div class="text-text-muted">🎨 Tailwind CSS + GSAP</div>
      <div class="text-text-muted">🖥️ Intel N97 MiniPC</div>
      <div class="text-text-muted">🐳 Docker + Caddy</div>
      <div class="text-text-muted">☁️ Cloudflare Tunnel</div>
      <div class="text-text-muted">🤖 OpenClaw AI Agent</div>
      <div class="text-accent-green mt-2">€0/Monat Cloud-Kosten</div>
    </div>
  </div>
</div>

<!-- Custom cursor elements -->
<div id="cursor-ring" class="fixed w-8 h-8 rounded-full border border-accent-purple/50 pointer-events-none z-[9998] -translate-x-1/2 -translate-y-1/2 transition-transform duration-150 hidden md:block" style="top:-100px;left:-100px"></div>
<div id="cursor-dot" class="fixed w-1.5 h-1.5 rounded-full bg-accent-purple pointer-events-none z-[9998] -translate-x-1/2 -translate-y-1/2 hidden md:block" style="top:-100px;left:-100px"></div>

<!-- Easter Egg Notification -->
<div id="easter-egg-toast" class="fixed top-20 left-1/2 -translate-x-1/2 z-[9999] opacity-0 pointer-events-none transition-all duration-500 transform -translate-y-4">
  <div class="glass-card px-6 py-3 flex items-center gap-3">
    <span class="text-2xl" id="egg-icon">🥚</span>
    <div>
      <div class="text-sm font-mono text-accent-purple" id="egg-title">Easter Egg!</div>
      <div class="text-xs text-text-muted" id="egg-desc">Du hast etwas Geheimes gefunden.</div>
    </div>
  </div>
</div>

<script>
  import { wpAjax } from '../../lib/api'

  // ===== BOOT SEQUENCE =====
  const overlay = document.getElementById('boot-overlay')
  const bootText = document.getElementById('boot-text')
  const bootBar = document.getElementById('boot-bar')
  const bootMessages = [
    'Initializing NEO system...',
    'Loading neural pathways...',
    'Connecting to homelab cluster...',
    'Mounting /dev/consciousness...',
    'Loading service catalog...',
    'Deploying showcase interface...',
    'System ready. Willkommen.',
  ]

  let bootIdx = 0
  function bootStep() {
    if (bootIdx < bootMessages.length) {
      const line = document.createElement('div')
      line.textContent = bootMessages[bootIdx]
      bootText?.appendChild(line)
      if (bootBar) bootBar.style.width = `${((bootIdx + 1) / bootMessages.length) * 100}%`
      bootIdx++
      setTimeout(bootStep, 200 + Math.random() * 150)
    } else {
      setTimeout(() => {
        if (overlay) {
          overlay.style.opacity = '0'
          setTimeout(() => overlay.remove(), 500)
        }
      }, 400)
    }
  }

  if (sessionStorage.getItem('neo_booted')) {
    overlay?.remove()
  } else {
    sessionStorage.setItem('neo_booted', '1')
    bootStep()
  }

  // ===== BACK TO TOP =====
  const btn = document.getElementById('back-to-top')
  window.addEventListener('scroll', () => {
    if (!btn) return
    if (window.scrollY > 400) {
      btn.classList.remove('opacity-0', 'pointer-events-none')
      btn.classList.add('opacity-100', 'pointer-events-auto')
    } else {
      btn.classList.add('opacity-0', 'pointer-events-none')
      btn.classList.remove('opacity-100', 'pointer-events-auto')
    }
  }, { passive: true })
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))

  // ===== VISITOR COUNTER =====
  async function fetchVisitors() {
    const data = await wpAjax<any>('neo_visitor_count')
    const el = document.getElementById('visitor-count')
    if (el && data?.count) el.textContent = String(data.count)
  }
  fetchVisitors()

  // ===== CUSTOM CURSOR =====
  const ring = document.getElementById('cursor-ring')
  const dot = document.getElementById('cursor-dot')
  if (ring && dot && window.matchMedia('(pointer: fine)').matches) {
    document.addEventListener('mousemove', (e) => {
      dot.style.top = `${e.clientY}px`
      dot.style.left = `${e.clientX}px`
      ring.style.top = `${e.clientY}px`
      ring.style.left = `${e.clientX}px`
    })
    document.addEventListener('mousedown', () => ring.style.transform = 'translate(-50%,-50%) scale(0.8)')
    document.addEventListener('mouseup', () => ring.style.transform = 'translate(-50%,-50%) scale(1)')
    document.querySelectorAll('a, button, input, textarea, select, [role="button"]').forEach(el => {
      el.addEventListener('mouseenter', () => ring.style.transform = 'translate(-50%,-50%) scale(1.5)')
      el.addEventListener('mouseleave', () => ring.style.transform = 'translate(-50%,-50%) scale(1)')
    })
  }

  // ===== EASTER EGG TOAST SYSTEM =====
  const foundEggs = new Set<string>(JSON.parse(sessionStorage.getItem('neo_eggs') || '[]'))

  function showEasterEgg(id: string, icon: string, title: string, desc: string) {
    if (foundEggs.has(id)) return
    foundEggs.add(id)
    sessionStorage.setItem('neo_eggs', JSON.stringify([...foundEggs]))

    const toast = document.getElementById('easter-egg-toast')
    const eggIcon = document.getElementById('egg-icon')
    const eggTitle = document.getElementById('egg-title')
    const eggDesc = document.getElementById('egg-desc')
    if (!toast || !eggIcon || !eggTitle || !eggDesc) return

    eggIcon.textContent = icon
    eggTitle.textContent = title
    eggDesc.textContent = desc
    toast.style.opacity = '1'
    toast.style.transform = 'translateX(-50%) translateY(0)'
    setTimeout(() => {
      toast.style.opacity = '0'
      toast.style.transform = 'translateX(-50%) translateY(-16px)'
    }, 3000)
  }

  // ===== KONAMI CODE =====
  const konamiSequence = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a']
  let konamiIdx = 0
  document.addEventListener('keydown', (e) => {
    if (e.key === konamiSequence[konamiIdx]) {
      konamiIdx++
      if (konamiIdx === konamiSequence.length) {
        konamiIdx = 0
        activateMatrix()
        showEasterEgg('konami', '🕹️', 'Konami Code!', '↑↑↓↓←→←→BA — Du bist ein Klassiker.')
      }
    } else {
      konamiIdx = 0
    }
  })

  // ===== EASTER EGG: Type "neo" anywhere =====
  let neoBuffer = ''
  document.addEventListener('keypress', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return
    neoBuffer += e.key.toLowerCase()
    if (neoBuffer.length > 10) neoBuffer = neoBuffer.slice(-10)
    if (neoBuffer.includes('neo')) {
      neoBuffer = ''
      showEasterEgg('neo-type', '🦞', 'Du hast mich gerufen!', 'Neo ist immer da. Immer aufmerksam.')
    }
  })

  // ===== EASTER EGG: Rapid scroll (scrolling like crazy) =====
  let scrollCount = 0
  let scrollTimer: ReturnType<typeof setTimeout>
  window.addEventListener('scroll', () => {
    scrollCount++
    clearTimeout(scrollTimer)
    scrollTimer = setTimeout(() => { scrollCount = 0 }, 1000)
    if (scrollCount > 30) {
      scrollCount = 0
      showEasterEgg('speed-scroll', '🏎️', 'Speed Runner!', 'Du scrollst schneller als Neo deployen kann.')
    }
  }, { passive: true })

  // ===== EASTER EGG: Click avatar 5 times =====
  let avatarClicks = 0
  document.getElementById('avatar-wrapper')?.addEventListener('click', () => {
    avatarClicks++
    if (avatarClicks >= 5) {
      avatarClicks = 0
      showEasterEgg('avatar-click', '👽', 'Vertrau niemandem!', 'Nicht mal deinem eigenen Avatar.')
    }
  })

  // ===== MATRIX RAIN =====
  function activateMatrix() {
    const canvas = document.createElement('canvas')
    canvas.id = 'matrix-rain'
    canvas.style.cssText = 'position:fixed;inset:0;z-index:9990;pointer-events:none;opacity:0.8'
    document.body.appendChild(canvas)
    const ctx = canvas.getContext('2d')!
    canvas.width = window.innerWidth
    canvas.height = window.innerHeight
    const cols = Math.floor(canvas.width / 14)
    const drops = Array(cols).fill(1)
    const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789'

    function draw() {
      ctx.fillStyle = 'rgba(0,0,0,0.05)'
      ctx.fillRect(0, 0, canvas.width, canvas.height)
      ctx.fillStyle = '#0f0'
      ctx.font = '14px monospace'
      for (let i = 0; i < drops.length; i++) {
        ctx.fillText(chars[Math.floor(Math.random() * chars.length)], i * 14, drops[i] * 14)
        if (drops[i] * 14 > canvas.height && Math.random() > 0.975) drops[i] = 0
        drops[i]++
      }
    }

    const interval = setInterval(draw, 50)
    setTimeout(() => {
      clearInterval(interval)
      canvas.style.transition = 'opacity 1s'
      canvas.style.opacity = '0'
      setTimeout(() => canvas.remove(), 1000)
    }, 6000)
  }
</script>
