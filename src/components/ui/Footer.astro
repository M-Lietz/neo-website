---
/**
 * Footer — Showcase branding + nav + social links
 */
---

<footer class="relative py-16 px-6 border-t border-border-glass" data-animate>
  <div class="max-w-5xl mx-auto">
    <!-- Top: Quick Nav -->
    <div class="flex flex-wrap justify-center gap-6 mb-8 text-sm">
      <a href="#hero" class="text-text-secondary hover:text-accent-purple transition-colors font-mono">Start</a>
      <a href="#about-neo" class="text-text-secondary hover:text-accent-purple transition-colors font-mono">Projekt</a>
      <a href="#dashboard" class="text-text-secondary hover:text-accent-purple transition-colors font-mono">Dashboard</a>
      <a href="#terminal" class="text-text-secondary hover:text-accent-purple transition-colors font-mono">Terminal</a>
      <a href="#techstack" class="text-text-secondary hover:text-accent-purple transition-colors font-mono">Tech</a>
      <a href="#timeline" class="text-text-secondary hover:text-accent-purple transition-colors font-mono">Mein Weg</a>
      <a href="#connect" class="text-text-secondary hover:text-accent-purple transition-colors font-mono">Connect</a>
    </div>

    <!-- Middle: Social Links -->
    <div class="flex justify-center gap-5 mb-8">
      <a href="https://github.com/merlinlietz" target="_blank" rel="noopener" class="glass-card px-4 py-2 text-xs font-mono text-text-secondary hover:text-accent-cyan transition-colors" aria-label="GitHub">
        🐙 GitHub
      </a>
      <a href="https://merlinlietz.com" target="_blank" rel="noopener" class="glass-card px-4 py-2 text-xs font-mono text-text-secondary hover:text-accent-cyan transition-colors" aria-label="Portfolio">
        🌐 Portfolio
      </a>
      <a href="https://t.me/merlin_neo_ai_bot" target="_blank" rel="noopener" class="glass-card px-4 py-2 text-xs font-mono text-text-secondary hover:text-accent-cyan transition-colors" aria-label="Telegram">
        💬 Telegram
      </a>
    </div>

    <!-- Bottom: Branding + Copyright -->
    <div class="text-center space-y-2">
      <p class="text-text-muted text-sm">
        <span class="text-accent-purple font-bold">NEO</span> —
        Self-Hosted <span class="text-accent-cyan">AI</span> auf Custom Hardware
      </p>
      <p class="text-text-muted text-xs">
        &copy; {new Date().getFullYear()} Merlin Lietz — Ein Homelab-Projekt
      </p>
      <p class="text-text-muted text-[10px] font-mono">
        Diese Seite läuft auf einem Intel N97 MiniPC · Docker · Caddy · Cloudflare
      </p>
    </div>
  </div>
</footer>
